generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  WAREHOUSE_USER
  PICKER
}

enum AppFeature {
  DASHBOARD
  SCAN
  PRODUCTS
  PRODUCT_DELETE
  INVENTORY
  RECEIVING
  PICKING
  MOVEMENT
  WAREHOUSES
  LOCATIONS
  TRANSACTIONS
  USERS
  SETTINGS
  CHAT
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum DisableRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

enum ProductStatus {
  ACTIVE
  DISABLED
}

enum WarehouseStatus {
  ACTIVE
  INACTIVE
}

enum LocationStatus {
  ACTIVE
  INACTIVE
}

enum TransactionType {
  STOCK_RECEIVED
  STOCK_MOVED
  STOCK_PICKED
  STOCK_ADJUSTED
  STOCK_RETURNED
}

enum AdjustmentReason {
  DAMAGE
  LOST
  FOUND
  COUNT_CORRECTION
  OTHER
}

model Organization {
  id            String   @id @default(cuid())
  orgCode       String   @unique @map("org_code")
  name          String
  tradingName   String   @map("trading_name")
  ownerName     String   @map("owner_name")
  email         String
  contactNumber String   @map("contact_number")
  slug          String   @unique
  logoUrl             String?  @map("logo_url")
  loginBackgroundUrl  String?  @map("login_background_url")
  themeColor          String?  @map("theme_color")
  createdAt     DateTime @default(now()) @map("created_at")

  users      User[]
  products   Product[]
  warehouses Warehouse[]
  chatMessages ChatMessage[]
  chatGroups ChatGroup[]

  @@index([orgCode])
  @@index([slug])
  @@map("organizations")
}

model User {
  id             String     @id @default(cuid())
  organizationId String     @map("organization_id")
  name           String
  email          String
  profilePhotoUrl String?   @map("profile_photo_url")
  passwordHash   String     @map("password_hash")
  role           UserRole   @default(WAREHOUSE_USER)
  status         UserStatus @default(ACTIVE)
  extraFeatures  AppFeature[] @default([]) @map("extra_features")
  chatLastSeenAt DateTime?  @map("chat_last_seen_at")
  createdAt      DateTime   @default(now()) @map("created_at")

  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  transactions           InventoryTransaction[]
  devices                Device[]
  disableRequestsTarget  UserDisableRequest[] @relation("DisableTarget")
  disableRequestsMade    UserDisableRequest[] @relation("DisableRequester")
  chatMessagesSent       ChatMessage[]        @relation("ChatSender")
  chatMessagesReceived   ChatMessage[]        @relation("ChatRecipient")
  chatGroupsCreated      ChatGroup[]          @relation("ChatGroupCreator")
  chatGroupMemberships   ChatGroupMember[]

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([email])
  @@index([role])
  @@map("users")
}

model Product {
  id                String        @id @default(cuid())
  organizationId    String        @map("organization_id")
  sku               String
  barcode           String
  name              String
  description       String?
  category          String?
  imageUrl          String?       @map("image_url")
  status            ProductStatus @default(ACTIVE)
  minimumStockLevel Int           @default(0) @map("minimum_stock_level")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  images       ProductImage[]
  inventory    Inventory[]
  transactions InventoryTransaction[]

  @@unique([organizationId, sku])
  @@unique([organizationId, barcode])
  @@index([organizationId])
  @@index([sku])
  @@index([barcode])
  @@index([status])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  url       String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model Warehouse {
  id             String          @id @default(cuid())
  organizationId String          @map("organization_id")
  code           String
  name           String
  address        String?
  status         WarehouseStatus @default(ACTIVE)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  organization            Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  locations               Location[]
  inventory               Inventory[]
  sourceTransactions      InventoryTransaction[] @relation("SourceWarehouse")
  destinationTransactions InventoryTransaction[] @relation("DestinationWarehouse")

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([code])
  @@index([status])
  @@map("warehouses")
}

model Location {
  id          String         @id @default(cuid())
  warehouseId String         @map("warehouse_id")
  code        String
  zone        String?
  aisle       String?
  rack        String?
  shelf       String?
  bin         String?
  status      LocationStatus @default(ACTIVE)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  warehouse               Warehouse              @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  inventory               Inventory[]
  sourceTransactions      InventoryTransaction[] @relation("SourceLocation")
  destinationTransactions InventoryTransaction[] @relation("DestinationLocation")

  @@unique([warehouseId, code])
  @@index([warehouseId])
  @@index([code])
  @@map("locations")
}

model Inventory {
  id               String   @id @default(cuid())
  productId        String   @map("product_id")
  warehouseId      String   @map("warehouse_id")
  locationId       String   @map("location_id")
  quantity         Int      @default(0)
  reservedQuantity Int      @default(0) @map("reserved_quantity")
  updatedAt        DateTime @updatedAt @map("updated_at")

  product   Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  location  Location  @relation(fields: [locationId], references: [id], onDelete: Restrict)

  @@unique([productId, warehouseId, locationId])
  @@index([productId])
  @@index([warehouseId])
  @@index([locationId])
  @@map("inventory")
}

model Device {
  id         String    @id @default(cuid())
  deviceId   String    @unique @map("device_id")
  name       String?
  platform   String?
  userId     String?   @map("user_id")
  lastSeenAt DateTime? @map("last_seen_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user         User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  transactions InventoryTransaction[]

  @@index([deviceId])
  @@map("devices")
}

model InventoryTransaction {
  id                     String            @id @default(cuid())
  type                   TransactionType
  productId              String            @map("product_id")
  sku                    String
  quantity               Int
  sourceWarehouseId      String?           @map("source_warehouse_id")
  sourceLocationId       String?           @map("source_location_id")
  destinationWarehouseId String?           @map("destination_warehouse_id")
  destinationLocationId  String?           @map("destination_location_id")
  userId                 String            @map("user_id")
  deviceRecordId         String?           @map("device_record_id")
  reference              String?
  notes                  String?
  adjustmentReason       AdjustmentReason? @map("adjustment_reason")
  createdAt              DateTime          @default(now()) @map("created_at")

  product              Product    @relation(fields: [productId], references: [id], onDelete: Restrict)
  user                 User       @relation(fields: [userId], references: [id], onDelete: Restrict)
  device               Device?    @relation(fields: [deviceRecordId], references: [id], onDelete: SetNull)
  sourceWarehouse      Warehouse? @relation("SourceWarehouse", fields: [sourceWarehouseId], references: [id], onDelete: Restrict)
  sourceLocation       Location?  @relation("SourceLocation", fields: [sourceLocationId], references: [id], onDelete: Restrict)
  destinationWarehouse Warehouse? @relation("DestinationWarehouse", fields: [destinationWarehouseId], references: [id], onDelete: Restrict)
  destinationLocation  Location?  @relation("DestinationLocation", fields: [destinationLocationId], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([sku])
  @@index([type])
  @@index([createdAt])
  @@index([sourceWarehouseId])
  @@index([sourceLocationId])
  @@index([destinationWarehouseId])
  @@index([destinationLocationId])
  @@index([userId])
  @@map("inventory_transactions")
}

model UserDisableRequest {
  id            String               @id @default(cuid())
  targetUserId  String               @map("target_user_id")
  requestedById String               @map("requested_by_id")
  status        DisableRequestStatus @default(PENDING)
  createdAt     DateTime             @default(now()) @map("created_at")
  resolvedAt    DateTime?            @map("resolved_at")

  targetUser  User @relation("DisableTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  requestedBy User @relation("DisableRequester", fields: [requestedById], references: [id], onDelete: Cascade)

  @@index([targetUserId, status])
  @@index([requestedById])
  @@map("user_disable_requests")
}

enum ChatAttachmentType {
  IMAGE
  VIDEO
  FILE
}

model ChatMessage {
  id                 String               @id @default(cuid())
  organizationId     String               @map("organization_id")
  senderId           String               @map("sender_id")
  recipientId        String?              @map("recipient_id")
  groupId            String?              @map("group_id")
  body               String               @default("")
  attachmentType     ChatAttachmentType?  @map("attachment_type")
  attachmentUrl      String?              @map("attachment_url")
  attachmentName     String?              @map("attachment_name")
  attachmentMimeType String?              @map("attachment_mime_type")
  attachmentSize     Int?                 @map("attachment_size")
  replyToMessageId   String?              @map("reply_to_message_id")
  forwardedFromId    String?              @map("forwarded_from_id")
  deletedForEveryoneAt DateTime?          @map("deleted_for_everyone_at")
  hiddenForSenderAt    DateTime?            @map("hidden_for_sender_at")
  hiddenForRecipientAt DateTime?          @map("hidden_for_recipient_at")
  deliveredAt        DateTime?            @map("delivered_at")
  readAt             DateTime?            @map("read_at")
  createdAt          DateTime             @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  sender       User         @relation("ChatSender", fields: [senderId], references: [id], onDelete: Restrict)
  recipient    User?        @relation("ChatRecipient", fields: [recipientId], references: [id], onDelete: Restrict)
  group        ChatGroup?   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  replyTo      ChatMessage? @relation("ChatReply", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies      ChatMessage[] @relation("ChatReply")
  forwardedFrom ChatMessage? @relation("ChatForward", fields: [forwardedFromId], references: [id], onDelete: SetNull)
  forwards     ChatMessage[] @relation("ChatForward")

  @@index([organizationId])
  @@index([senderId, recipientId])
  @@index([recipientId, readAt])
  @@index([groupId, createdAt])
  @@index([createdAt])
  @@map("chat_messages")
}

model ChatGroup {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  createdById    String   @map("created_by_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  createdBy    User             @relation("ChatGroupCreator", fields: [createdById], references: [id], onDelete: Restrict)
  members      ChatGroupMember[]
  messages     ChatMessage[]

  @@index([organizationId])
  @@index([createdById])
  @@map("chat_groups")
}

model ChatGroupMember {
  id         String    @id @default(cuid())
  groupId    String    @map("group_id")
  userId     String    @map("user_id")
  canSend    Boolean   @default(true) @map("can_send")
  lastReadAt DateTime? @map("last_read_at")
  joinedAt   DateTime  @default(now()) @map("joined_at")

  group ChatGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
  @@map("chat_group_members")
}
