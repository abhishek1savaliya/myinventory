# PostgreSQL connection string
# Local example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/myinventory?schema=public"
# DIRECT_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/myinventory?schema=public"
# Neon/cloud example (SSL required):
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
# (Remove "-pooler" from the hostname for DIRECT_DATABASE_URL — required for Prisma migrations)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/myinventory?schema=public"
DIRECT_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/myinventory?schema=public"

# API server
API_PORT=3847
API_HOST=127.0.0.1

# JWT secret (change in production — minimum 16 characters)
JWT_SECRET="change-me-to-a-long-random-string-in-production"
JWT_EXPIRES_IN="8h"

# Electron renderer talks to API at this URL
VITE_API_URL="http://127.0.0.1:3847"

# Next.js web app talks to the same API (base URL only — do NOT append /api)
NEXT_PUBLIC_API_URL="http://127.0.0.1:3847"

# Supabase (API access logs stored in Storage — not exposed to users)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SECRET_KEY="your-service-role-secret-key"
SUPABASE_LOGS_BUCKET="api-logs"
SUPABASE_PRODUCTS_BUCKET="product-images"
SUPABASE_SESSIONS_BUCKET="user-sessions"

# Upstash Redis (response caching)
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-rest-token"
CACHE_TTL_CATALOG_SECONDS=300
CACHE_TTL_INVENTORY_SECONDS=60